{
  "name": "noiget-backend",
  "version": "1.0.0",
  "description": "NOGIET - Nigerian Oil and Gas Methane Portal Backend API",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit",
    "start": "tsx src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/lib-storage": "^3.750.0",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/swagger": "^9.3.1",
    "@fastify/swagger-ui": "^5.2.1",
    "@turf/boolean-point-in-polygon": "^7.3.4",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.2.1",
    "ioredis": "^5.9.3",
    "node-cron": "^4.2.1",
    "pg": "^8.13.1",
    "pino-pretty": "^13.0.0",
    "resend": "^4.5.1",
    "socket.io": "^4.8.3",
    "tsx": "^4.19.2",
    "undici": "^8.3.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "better-sqlite3": "^11.7.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
